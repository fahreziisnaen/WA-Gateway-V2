# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Change this to a long, random secret before deploying
API_KEY=change_this_to_a_secure_random_key

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Paths ─────────────────────────────────────────────────────────────────────
SESSION_DIR=./sessions
LOG_FILE=./logs/messages.log
