# =============================================================================
# Phillip WA Gateway — Environment Variables
# =============================================================================
# 1. Copy this file:        cp .env.example .env
# 2. Fill in every value marked  ← REQUIRED
# 3. Generate secrets where shown using the openssl commands
# =============================================================================

# ── Backend ───────────────────────────────────────────────────────────────────

PORT=3000

# JWT secret — signs all admin dashboard session tokens.
# ← REQUIRED  Generate with:  openssl rand -hex 32
JWT_SECRET=

# (Optional) Legacy static API key for external integrations that cannot use
# the dashboard. API keys are normally created inside Settings → API Keys.
# Leave blank unless you have a specific need for a pre-set key.
API_KEY=

# ── Queue ─────────────────────────────────────────────────────────────────────

# Number of messages processed in parallel by the BullMQ worker.
QUEUE_CONCURRENCY=2

# ── Redis ─────────────────────────────────────────────────────────────────────

# Must match the service name in docker-compose.yml (do not change for Docker).
REDIS_HOST=redis
REDIS_PORT=6379

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite file path inside the backend container.
# Set automatically by docker-compose — only change if running outside Docker.
DB_PATH=/app/data/gateway.db

# ── SQLite Web (database browser at http://<host>:3002) ──────────────────────
# ← REQUIRED  Change this before deploying — default is intentionally blank.
# Generate with:  openssl rand -base64 16
SQLITE_WEB_PASSWORD=

# ── Paths ─────────────────────────────────────────────────────────────────────

# WhatsApp session directory (relative to the backend container's /app).
# Only change if running outside Docker.
SESSION_DIR=./sessions

# ── Frontend (Vite build) ─────────────────────────────────────────────────────
# Not required — the admin dashboard authenticates via JWT (username + password).
# Only needed for legacy direct API key usage from the browser.
VITE_API_KEY=
