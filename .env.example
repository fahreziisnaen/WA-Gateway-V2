# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Gateway — Environment Variables
# Copy this file to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3000

# API key required in the x-api-key header for protected endpoints.
# Generate a strong random value: openssl rand -hex 32
API_KEY=change_this_to_a_secure_random_key

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Paths (relative to the backend container's /app) ─────────────────────────
SESSION_DIR=./sessions
LOG_FILE=./logs/messages.log

# ── Frontend build (VITE_ prefix exposes vars to the browser bundle) ──────────
# Must match API_KEY above so the admin UI can authenticate.
VITE_API_KEY=change_this_to_a_secure_random_key
